{
  "name": "adoraads-waitlist",
  "version": "1.0.0",
  "description": "adoraads.ai waitlist server — captures signups, sends welcome emails, syncs to Mailchimp",
  "main": "waitlist-server.js",
  "scripts": {
    "start": "node waitlist-server.js",
    "dev": "nodemon waitlist-server.js",
    "test": "node test-waitlist.js",
    "lint": "eslint *.js --fix",
    "lint:check": "eslint *.js",
    "qa": "npm run lint:check",
    "build": "npm run lint && npm run qa",
    "deploy:railway": "railway up",
    "deploy:check": "npm run build && npm run test",
    "prestart": "node scripts/validate-env.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "nodemon": "^3.0.0"
  }
}
